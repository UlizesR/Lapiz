{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 19, "patch": 0 },
  "configurePresets": [
    {
      "name": "opengl",
      "displayName": "OpenGL",
      "binaryDir": "${sourceDir}/build-ogl",
      "cacheVariables": {
        "LAPIZ_OPENGL": "ON",
        "LAPIZ_VULKAN": "OFF",
        "LAPIZ_METAL": "OFF"
      }
    },
    {
      "name": "vulkan",
      "displayName": "Vulkan",
      "binaryDir": "${sourceDir}/build-vk",
      "cacheVariables": {
        "LAPIZ_OPENGL": "OFF",
        "LAPIZ_VULKAN": "ON",
        "LAPIZ_METAL": "OFF"
      }
    },
    {
      "name": "metal",
      "displayName": "Metal",
      "binaryDir": "${sourceDir}/build-mtl",
      "cacheVariables": {
        "LAPIZ_OPENGL": "OFF",
        "LAPIZ_VULKAN": "OFF",
        "LAPIZ_METAL": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "opengl",
      "configurePreset": "opengl"
    },
    {
      "name": "vulkan",
      "configurePreset": "vulkan"
    },
    {
      "name": "metal",
      "configurePreset": "metal"
    }
  ]
}
