{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 19, "patch": 0 },
  "configurePresets": [
    { "name": "opengl", "displayName": "OpenGL", "binaryDir": "${sourceDir}/build-ogl", "cacheVariables": { "LAPIZ_OPENGL": "ON", "LAPIZ_VULKAN": "OFF", "LAPIZ_METAL": "OFF" } },
    { "name": "vulkan", "displayName": "Vulkan", "binaryDir": "${sourceDir}/build-vk", "cacheVariables": { "LAPIZ_OPENGL": "OFF", "LAPIZ_VULKAN": "ON", "LAPIZ_METAL": "OFF" } },
    { "name": "metal", "displayName": "Metal (GLFW)", "binaryDir": "${sourceDir}/build-mtl", "cacheVariables": { "LAPIZ_OPENGL": "OFF", "LAPIZ_VULKAN": "OFF", "LAPIZ_METAL": "ON" } },
    { "name": "sdl-mtl", "displayName": "SDL + Metal", "binaryDir": "${sourceDir}/build-sdl", "cacheVariables": { "LAPIZ_USE_SDL": "ON", "LAPIZ_OPENGL": "OFF", "LAPIZ_VULKAN": "OFF", "LAPIZ_METAL": "ON" } },
    { "name": "sdl-ogl", "displayName": "SDL + OpenGL", "binaryDir": "${sourceDir}/build-sdl-ogl", "cacheVariables": { "LAPIZ_USE_SDL": "ON", "LAPIZ_OPENGL": "ON", "LAPIZ_VULKAN": "OFF", "LAPIZ_METAL": "OFF" } },
    { "name": "sdl-vk", "displayName": "SDL + Vulkan", "binaryDir": "${sourceDir}/build-sdl-vk", "cacheVariables": { "LAPIZ_USE_SDL": "ON", "LAPIZ_OPENGL": "OFF", "LAPIZ_VULKAN": "ON", "LAPIZ_METAL": "OFF" } }
  ],
  "buildPresets": [
    { "name": "opengl", "configurePreset": "opengl" },
    { "name": "vulkan", "configurePreset": "vulkan" },
    { "name": "metal", "configurePreset": "metal" },
    { "name": "sdl-mtl", "configurePreset": "sdl-mtl" },
    { "name": "sdl-ogl", "configurePreset": "sdl-ogl" },
    { "name": "sdl-vk", "configurePreset": "sdl-vk" }
  ]
}
